---
import { SITE, NAV } from '../config/theme';

interface Props {
  currentPath?: string;
}
const { currentPath = '' } = Astro.props;
---

<header class="sticky top-0 z-50 border-b border-gray-200 bg-white/95 backdrop-blur-sm">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">

      <!-- Logo / Site name -->
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-9 h-9 rounded-lg bg-accent-800 flex items-center justify-center
                    group-hover:bg-accent-700 transition-colors flex-shrink-0">
          <!-- Compass / atlas icon -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24"
               fill="none" stroke="white" stroke-width="2"
               stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5">
            <circle cx="12" cy="12" r="10"/>
            <polygon points="16.24 7.76 14.12 14.12 7.76 16.24 9.88 9.88 16.24 7.76" fill="white" stroke="none"/>
          </svg>
        </div>
        <div>
          <span class="font-extrabold text-accent-800 text-lg leading-none tracking-tight">
            {SITE.name}
          </span>
          <span class="block text-[10px] font-medium text-gray-400 leading-none mt-0.5 tracking-wider uppercase">
            {SITE.tagline}
          </span>
        </div>
      </a>

      <!-- Nav links -->
      <nav class="hidden md:flex items-center gap-1">
        {NAV.map((section) => (
          <a
            href={section.items[0].href}
            class="text-sm px-3 py-2 rounded-lg font-semibold transition-colors
                   text-gray-600 hover:text-accent-800 hover:bg-accent-50"
          >
            {section.section}
          </a>
        ))}

        <div class="w-px h-5 bg-gray-200 mx-2"></div>

        <!-- AIRLab Website -->
        <a href="https://airlab.deib.polimi.it/"
           class="flex items-center p-2 rounded-lg text-gray-500 hover:text-accent-800 hover:bg-accent-50 transition-colors"
           aria-label="AIRLab Website" target="_blank" rel="noopener">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
        </a>

        <!-- LinkedIn -->
        <a href="https://www.linkedin.com/company/airlab-polimi/"
           class="flex items-center p-2 rounded-lg text-gray-500 hover:text-accent-800 hover:bg-accent-50 transition-colors"
           aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>

        <!-- Instagram -->
        <a href="https://www.instagram.com/airlab_polimi/"
           class="flex items-center p-2 rounded-lg text-gray-500 hover:text-accent-800 hover:bg-accent-50 transition-colors"
           aria-label="Instagram" target="_blank" rel="noopener">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
            <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
          </svg>
        </a>

        <!-- HuggingFace -->
        <a href="https://huggingface.co/AIRLab-POLIMI"
           class="flex items-center p-2 rounded-lg text-gray-500 hover:text-accent-800 hover:bg-accent-50 transition-colors"
           aria-label="HuggingFace" target="_blank" rel="noopener">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 1C5.925 1 1 5.925 1 12s4.925 11 11 11 11-4.925 11-11S18.075 1 12 1zm0 2c4.971 0 9 4.029 9 9s-4.029 9-9 9-9-4.029-9-9 4.029-9 9-9zm-3.5 6a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm7 0a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zm-7.25 5c.41 1.75 1.96 3 3.75 3s3.34-1.25 3.75-3h-7.5z"/>
          </svg>
        </a>
      </nav>

      <!-- Mobile toggle (placeholder) -->
      <button class="md:hidden p-2 rounded-lg text-gray-500 hover:text-gray-900 hover:bg-gray-100">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2"
             viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6" x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </button>

    </div>
  </div>
</header>
