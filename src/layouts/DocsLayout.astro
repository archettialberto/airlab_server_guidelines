---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Sidebar from '../components/Sidebar.astro';

interface Props {
  title: string;
  description?: string;
  /** Table-of-contents entries: { label, id } shown on the right rail */
  toc?: { label: string; id: string }[];
}

const { title, description, toc = [] } = Astro.props;
const currentPath = new URL(Astro.request.url).pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="min-h-screen bg-white overflow-y-scroll">
    <Header currentPath={currentPath} />

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex gap-8 pt-8 pb-24">

        <!-- ── Left sidebar ───────────────────────────────── -->
        <Sidebar currentPath={currentPath} />

        <!-- ── Main content ───────────────────────────────── -->
        <main class="flex-1 min-w-0 doc-content">
          <slot />
        </main>

        <!-- ── Right TOC rail ─────────────────────────────── -->
        {toc.length > 0 && (
          <aside class="hidden xl:block w-52 flex-shrink-0">
            <div class="sticky top-24">
              <p class="text-[10px] font-bold uppercase tracking-widest text-gray-400 mb-3">
                On this page
              </p>
              <ul class="space-y-1.5 border-l border-gray-100 pl-3">
                {toc.map((item) => (
                  <li>
                    <a
                      href={`#${item.id}`}
                      class="text-sm text-gray-500 hover:text-accent-700 transition-colors block py-0.5"
                    >
                      {item.label}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        )}

      </div>
    </div>
  </body>
</html>
