---
import DocsLayout from '../../layouts/DocsLayout.astro';
import CodeBlock from '../../components/CodeBlock.astro';

const toc = [
  { label: 'Publication Venues',   id: 'venues' },
];

// Curly braces inside template literals are interpreted as JSX expressions in Astro.
// Store code blocks containing them as plain string variables in the frontmatter.
const latexBibCode = [
  '% In your preamble',
  '\\usepackage[style=ieee,backend=biber]{biblatex}',
  '\\addbibresource{references.bib}',
  '',
  '% In your text',
  'As shown by~\\cite{He2016ResNets}, deep residual learning...',
  '',
  '% At the end of the document',
  '\\printbibliography',
].join('\n');
---

<DocsLayout title="Thesis Dissertation" toc={toc}>

  <h1>Thesis Dissertation</h1>

  <img src="/dissertation.png" alt="Thesis Dissertation" style="width: 100%; max-width: 600px; margin: 1.5rem auto; display: block;" />

  <div class="callout callout-warning">
    <svg class="w-5 h-5 flex-shrink-0 mt-0.5 text-yellow-500" fill="none" stroke="currentColor"
         stroke-width="2" viewBox="0 0 24 24">
      <path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/>
      <line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>
    </svg>
    <div class="text-sm leading-relaxed">
      This page is under construction.
    </div>
  </div>

</DocsLayout>