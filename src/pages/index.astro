---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE, NAV } from '../config/theme';

const serverGuide = NAV[0];
const thesisGuide = NAV[1];

const sections = [
  {
    badge:    'Server Guide',
    title:    'Set up and use the AIRLab servers',
    desc:     'Learn how to connect, run experiments, manage resources responsibly, and keep your work reproducible. From your first SSH session to a fully containerised experiment.',
    href:     '/docs/welcome',
    cta:      'Start the server guide',
    items:    serverGuide.items,
    icon: `<rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="16" width="18" height="4" rx="1"/><circle cx="7" cy="6" r="0.8" fill="white" stroke="none"/><circle cx="7" cy="12" r="0.8" fill="white" stroke="none"/><circle cx="7" cy="18" r="0.8" fill="white" stroke="none"/>`,
  },
  {
    badge:    'Thesis Guide',
    title:    'Navigate your MSc thesis at AIRLab',
    desc:     'Find and evaluate research papers, understand publication venues, structure and write your thesis, and prepare a compelling final presentation.',
    href:     '/docs/research',
    cta:      'Start the thesis guide',
    items:    thesisGuide.items,
    icon: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE.title} description={SITE.description} />

    <!-- Three.js (required peer dep for Vanta) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <!-- Vanta GLOBE — animated rotating globe background -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.globe.min.js"></script>
  </head>

  <body class="min-h-screen bg-white">
    <Header />

    <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
    <!-- Vanta mounts its canvas at z-0; all content floats above via z-10    -->
    <section id="hero" class="relative overflow-hidden" style="background-color: #102c53; min-height: 520px;">

      <!-- Right-side vignette keeps globe from bleeding into text on large screens -->
      <div class="absolute inset-y-0 left-0 w-2/3 z-[2] pointer-events-none"
           style="background: linear-gradient(to right, #102c53 40%, transparent 100%);"></div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-28 z-[3] pointer-events-none"
           style="background: linear-gradient(to bottom, transparent, #102c53);"></div>

      <!-- Hero content — left-aligned per Polimi web design prescription -->
      <div class="relative z-10 max-w-6xl mx-auto px-6 sm:px-10 lg:px-16 pt-14 pb-16">

        <!-- ① Logo lockup ──────────────────────────────────────────────────── -->
        <!-- DEIB Bandiera already contains the Polimi seal + DEIB name -->
        <div class="mb-12">
          <img src="/logos/deib-white.png"
               alt="Politecnico di Milano — Department of Electronics, Information and Bioengineering"
               class="h-9 w-auto opacity-80" />
        </div>

        <!-- ② Eyebrow ──────────────────────────────────────────────────────── -->
        <div class="flex items-center gap-3 mb-5">
          <span class="block w-8 h-px" style="background-color: #4d87d4;"></span>
          <span class="text-xs font-bold uppercase tracking-widest" style="color: #4d87d4;">
            Artificial Intelligence &amp; Robotics Lab
          </span>
        </div>

        <!-- ③ Main heading ─────────────────────────────────────────────────── -->
        <h1 class="font-extrabold text-white leading-none mb-3"
            style="font-size: clamp(4rem, 10vw, 7rem); letter-spacing: -0.04em;">
          ATLAS
        </h1>
        <p class="text-xl font-medium mb-4" style="color: rgba(255,255,255,0.65);">
          The AIRLab User Handbook
        </p>

        <!-- ④ Sub-copy ──────────────────────────────────────────────────────── -->
        <p class="text-base leading-relaxed mb-10 max-w-lg" style="color: rgba(255,255,255,0.42);">
          Everything you need at the AI &amp; Robotics Lab —
          from your first SSH session to your final thesis submission.
        </p>

        <!-- ⑤ CTAs ─────────────────────────────────────────────────────────── -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/docs/welcome"
             class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-bold text-sm
                    bg-white text-accent-800 hover:bg-accent-50 transition-colors shadow-lg">
            Server Guide
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/docs/research"
             class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-bold text-sm
                    bg-white/10 border border-white/20 text-white hover:bg-white/20 transition-colors">
            Thesis Guide
          </a>
        </div>

        <!-- ⑥ Bottom metadata bar ─────────────────────────────────────────── -->
        <div class="mt-14 pt-5 flex items-center justify-between border-t" style="border-color: rgba(255,255,255,0.10);">
          <span class="text-xs uppercase tracking-widest" style="color: rgba(255,255,255,0.28);">
            ATLAS v{SITE.version}
          </span>
          <span class="text-xs" style="color: rgba(255,255,255,0.28);">
            Politecnico di Milano · DEIB
          </span>
        </div>
      </div>
    </section>

    <!-- ── Two-section cards ──────────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">

        {sections.map((s) => (
          <div class="group flex flex-col rounded-2xl border border-gray-100
                      hover:border-accent-100 hover:shadow-xl transition-all duration-300 overflow-hidden">

            <!-- Card header -->
            <div class="px-8 pt-8 pb-6 border-b border-gray-100">
              <div class="flex items-start gap-4 mb-5">
                <div class="w-10 h-10 rounded-xl bg-accent-800 flex items-center justify-center flex-shrink-0
                            group-hover:bg-accent-700 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="white" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"
                       set:html={s.icon} />
                </div>
                <div>
                  <span class="text-xs font-bold uppercase tracking-widest text-accent-600">
                    {s.badge}
                  </span>
                  <h2 class="text-lg font-extrabold text-gray-900 mt-0.5 leading-snug">
                    {s.title}
                  </h2>
                </div>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
            </div>

            <!-- Chapter list -->
            <ul class="flex-1 px-8 py-5 space-y-1.5">
              {s.items.map((item, i) => (
                <li>
                  <a href={item.href}
                     class="flex items-center gap-3 text-sm text-gray-600
                            hover:text-accent-800 transition-colors group/link py-1">
                    <span class="text-xs font-mono text-gray-300 w-4 text-right flex-shrink-0">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span class="group-hover/link:underline underline-offset-2">{item.label}</span>
                    <svg class="w-3 h-3 ml-auto opacity-0 group-hover/link:opacity-100 transition-opacity text-accent-500"
                         fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <div class="px-8 pb-7">
              <a href={s.href}
                 class="inline-flex items-center gap-2 text-sm font-bold text-accent-800
                        hover:text-accent-600 transition-colors">
                {s.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── About AIRLab strip ──────────────────────────────────────────────── -->
    <section class="border-t border-gray-100 bg-accent-50 py-14">
      <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
        <p class="text-sm font-bold uppercase tracking-widest text-accent-600 mb-3">About</p>
        <p class="text-gray-700 leading-relaxed">
          The <strong>Artificial Intelligence and Robotics Lab (AIRLab)</strong> is a research group
          at <strong>Politecnico di Milano</strong> working on machine learning, computer vision,
          and intelligent systems. ATLAS is the shared knowledge base maintained by lab members
          to onboard new researchers as smoothly as possible.
        </p>
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <footer class="py-8 border-t border-gray-100">
      <p class="text-center text-xs text-gray-400 font-medium">
        ATLAS v{SITE.version} · AIRLab · Politecnico di Milano ·
        Built with <a href="https://astro.build" class="text-accent-600 hover:underline">Astro</a> &
        <a href="https://tailwindcss.com" class="text-accent-600 hover:underline">Tailwind CSS</a>
      </p>
    </footer>

    <!-- ── Vanta NET initialisation ──────────────────────────────────────── -->
    <script is:inline>
      (function () {
        // Guard: only run when both libs loaded (they're synchronous CDN scripts)
        if (typeof VANTA === 'undefined' || typeof THREE === 'undefined') return;

        var effect = VANTA.GLOBE({
          el: '#hero',
          THREE: THREE,
          mouseControls: true,
          touchControls: true,
          gyroControls: false,
          // ── Colors (mirrors theme.config.js) ──────────────────────────
          backgroundColor: 0x102c53,  // Polimi Heritage Blue
          color:           0x4d87d4,  // accent-400 — globe line colour
          color2:          0x1e5299,  // accent-700 — secondary dot colour
          // ── Scale ─────────────────────────────────────────────────────
          size:        1.2,
          scale:       1.0,
          scaleMobile: 0.75,
        });

        // Clean up if the user navigates away (prevents memory leaks on SPAs)
        window.addEventListener('beforeunload', function () {
          if (effect && effect.destroy) effect.destroy();
        });
      })();
    </script>
  </body>
</html>
