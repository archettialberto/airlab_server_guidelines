---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import { SITE, NAV } from '../config/theme';

const serverGuide = NAV[0];
const thesisGuide = NAV[1];

const sections = [
  {
    badge:    'Server Guide',
    title:    'Set up and use the AIRLab servers',
    desc:     'Learn how to connect, run experiments, manage resources responsibly, and keep your work reproducible. From your first SSH session to a fully containerised experiment.',
    href:     '/docs/welcome',
    cta:      'Start the server guide',
    items:    serverGuide.items,
    icon: `<rect x="3" y="4" width="18" height="4" rx="1"/><rect x="3" y="10" width="18" height="4" rx="1"/><rect x="3" y="16" width="18" height="4" rx="1"/><circle cx="7" cy="6" r="0.8" fill="white" stroke="none"/><circle cx="7" cy="12" r="0.8" fill="white" stroke="none"/><circle cx="7" cy="18" r="0.8" fill="white" stroke="none"/>`,
  },
  {
    badge:    'Thesis Guide',
    title:    'Navigate your MSc thesis at AIRLab',
    desc:     'Find and evaluate research papers, understand publication venues, structure and write your thesis, and prepare a compelling final presentation.',
    href:     '/docs/research',
    cta:      'Start the thesis guide',
    items:    thesisGuide.items,
    icon: `<path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/>`,
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE.title} description={SITE.description} />

    <!-- Three.js (required peer dep for Vanta) -->
    <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r134/three.min.js"></script>
    <!-- Vanta GLOBE — animated rotating globe background -->
    <script is:inline src="https://cdn.jsdelivr.net/npm/vanta@0.5.24/dist/vanta.globe.min.js"></script>
  </head>

  <body class="min-h-screen bg-white">
    <Header />

    <!-- ── Hero ─────────────────────────────────────────────────────────────── -->
    <!-- Vanta mounts its canvas at z-0; all content floats above via z-10    -->
    <section id="hero" class="relative overflow-hidden" style="background-color: #102c53; min-height: 520px;">

      <!-- Right-side vignette keeps globe from bleeding into text on large screens -->
      <div class="absolute inset-y-0 left-0 w-2/3 z-[2] pointer-events-none"
           style="background: linear-gradient(to right, #102c53 40%, transparent 100%);"></div>
      <!-- Bottom fade -->
      <div class="absolute bottom-0 left-0 right-0 h-28 z-[3] pointer-events-none"
           style="background: linear-gradient(to bottom, transparent, #102c53);"></div>

      <!-- Hero content — left-aligned per Polimi web design prescription -->
      <div class="relative z-10 max-w-6xl mx-auto px-6 sm:px-10 lg:px-16 pt-14 pb-16">

        <!-- ① Logo lockup ──────────────────────────────────────────────────── -->
        <!-- DEIB Bandiera already contains the Polimi seal + DEIB name -->
        <div class="mb-12">
          <img src="/logos/deib-white.png"
               alt="Politecnico di Milano — Department of Electronics, Information and Bioengineering"
               class="h-16 w-auto opacity-85" />
        </div>

        <!-- ③ Main heading ─────────────────────────────────────────────────── -->
        <h1 class="font-extrabold text-white leading-none mb-3"
            style="font-size: clamp(4rem, 10vw, 7rem); letter-spacing: -0.04em;">
          ATLAS
        </h1>
        <p class="text-xl font-medium mb-4" style="color: rgba(255,255,255,0.65);">
          The AIRLab User Handbook
        </p>

        <!-- ④ Sub-copy ──────────────────────────────────────────────────────── -->
        <p class="text-base leading-relaxed mb-10 max-w-lg" style="color: rgba(255,255,255,0.42);">
          A guide to everything you need —
          from your first SSH session to your final thesis submission.
        </p>

        <!-- ⑤ CTAs ─────────────────────────────────────────────────────────── -->
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/docs/welcome"
             class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-bold text-sm
                    bg-white/10 border border-white/20 text-white hover:bg-white/20 transition-colors">
            Server Guide
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
          <a href="/docs/research"
             class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-xl font-bold text-sm
                    bg-white/10 border border-white/20 text-white hover:bg-white/20 transition-colors">
            Thesis Guide
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

      </div>
    </section>

    <!-- ── Two-section cards ──────────────────────────────────────────────── -->
    <section class="py-20 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 grid md:grid-cols-2 gap-8">

        {sections.map((s) => (
          <div class="group flex flex-col rounded-2xl border border-gray-100
                      hover:border-accent-100 hover:shadow-xl transition-all duration-300 overflow-hidden">

            <!-- Card header -->
            <div class="px-8 pt-8 pb-6 border-b border-gray-100">
              <div class="flex items-start gap-4 mb-5">
                <div class="w-10 h-10 rounded-xl bg-accent-800 flex items-center justify-center flex-shrink-0
                            group-hover:bg-accent-700 transition-colors">
                  <svg class="w-5 h-5" fill="none" stroke="white" stroke-width="2"
                       stroke-linecap="round" stroke-linejoin="round" viewBox="0 0 24 24"
                       set:html={s.icon} />
                </div>
                <div>
                  <span class="text-xs font-bold uppercase tracking-widest text-accent-600">
                    {s.badge}
                  </span>
                  <h2 class="text-lg font-extrabold text-gray-900 mt-0.5 leading-snug">
                    {s.title}
                  </h2>
                </div>
              </div>
              <p class="text-sm text-gray-600 leading-relaxed">{s.desc}</p>
            </div>

            <!-- Chapter list -->
            <ul class="flex-1 px-8 py-5 space-y-1.5">
              {s.items.map((item, i) => (
                <li>
                  <a href={item.href}
                     class="flex items-center gap-3 text-sm text-gray-600
                            hover:text-accent-800 transition-colors group/link py-1">
                    <span class="text-xs font-mono text-gray-300 w-4 text-right flex-shrink-0">
                      {String(i + 1).padStart(2, '0')}
                    </span>
                    <span class="group-hover/link:underline underline-offset-2">{item.label}</span>
                    <svg class="w-3 h-3 ml-auto opacity-0 group-hover/link:opacity-100 transition-opacity text-accent-500"
                         fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </li>
              ))}
            </ul>

            <!-- CTA -->
            <div class="px-8 pb-7">
              <a href={s.href}
                 class="inline-flex items-center gap-2 text-sm font-bold text-accent-800
                        hover:text-accent-600 transition-colors">
                {s.cta}
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24">
                  <path d="M5 12h14M12 5l7 7-7 7"/>
                </svg>
              </a>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- ── About AIRLab strip ──────────────────────────────────────────────── -->
    <section class="border-t border-gray-100 bg-accent-50 py-16">
      <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
        <p class="text-sm font-bold uppercase tracking-widest text-accent-600 mb-4 text-center">About AIRLab</p>
        <h2 class="text-2xl font-extrabold text-gray-900 text-center mb-6">
          One of Italy's longest-standing AI research groups
        </h2>
        <p class="text-gray-600 leading-relaxed text-center mb-10 max-w-2xl mx-auto">
          Founded in 1973 at <strong>Politecnico di Milano</strong>, the <strong>Artificial Intelligence and Robotics Lab (AIRLab)</strong>
          has over 50 years of history in AI, autonomous systems, and machine perception. The lab conducts both
          theoretical and applied research, hosts more than 30 PhD students and postdoc researchers, and produces over 60 master theses annually.
        </p>
        <!-- <div class="grid grid-cols-1 sm:grid-cols-3 gap-6 text-center">
          <div class="bg-white rounded-xl border border-accent-100 px-6 py-5">
            <p class="text-3xl font-extrabold text-accent-800 mb-1">50+</p>
            <p class="text-sm text-gray-500">Years of research in AI &amp; robotics</p>
          </div>
          <div class="bg-white rounded-xl border border-accent-100 px-6 py-5">
            <p class="text-3xl font-extrabold text-accent-800 mb-1">~15</p>
            <p class="text-sm text-gray-500">PhD students at any given time</p>
          </div>
          <div class="bg-white rounded-xl border border-accent-100 px-6 py-5">
            <p class="text-3xl font-extrabold text-accent-800 mb-1">50+</p>
            <p class="text-sm text-gray-500">Master theses completed annually</p>
          </div>
        </div> -->
      </div>
    </section>

    <!-- ── Footer ─────────────────────────────────────────────────────────── -->
    <footer style="background-color: #0d1117; color: #8b949e;">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-10 mb-10">

          <!-- Brand -->
          <div>
            <p class="font-extrabold text-white text-base mb-1">ATLAS</p>
            <p class="text-xs mb-4" style="color: #8b949e;">The AIRLab User Handbook</p>
            <p class="text-xs leading-relaxed" style="color: #8b949e;">
              Artificial Intelligence and Robotics Lab<br/>
              Politecnico di Milano — DEIB<br/>
              Via Ponzio 34/5, 20133 Milano, Italy
            </p>
          </div>

          <!-- Links -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-white mb-4">Resources</p>
            <ul class="space-y-2 text-xs">
              <li><a href="/docs/welcome" class="hover:text-white transition-colors">Server Guide</a></li>
              <li><a href="/docs/research" class="hover:text-white transition-colors">Thesis Guide</a></li>
              <li><a href="https://airlab.deib.polimi.it/" target="_blank" rel="noopener" class="hover:text-white transition-colors">AIRLab Website</a></li>
              <li><a href="https://huggingface.co/AIRLab-POLIMI" target="_blank" rel="noopener" class="hover:text-white transition-colors">HuggingFace</a></li>
            </ul>
          </div>

          <!-- Social -->
          <div>
            <p class="text-xs font-bold uppercase tracking-widest text-white mb-4">Connect</p>
            <div class="flex gap-3">
              <!-- AIRLab Website -->
              <a href="https://airlab.deib.polimi.it/" target="_blank" rel="noopener"
                 aria-label="AIRLab Website"
                 class="w-8 h-8 rounded-lg flex items-center justify-center transition-colors hover:bg-white/10 hover:text-white"
                 style="border: 1px solid #30363d;">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/>
                  <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
                </svg>
              </a>
              <!-- LinkedIn -->
              <a href="https://www.linkedin.com/company/airlab-polimi/" target="_blank" rel="noopener"
                 aria-label="LinkedIn"
                 class="w-8 h-8 rounded-lg flex items-center justify-center transition-colors hover:bg-white/10 hover:text-white"
                 style="border: 1px solid #30363d;">
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </a>
              <!-- Instagram -->
              <a href="https://www.instagram.com/airlab_polimi/" target="_blank" rel="noopener"
                 aria-label="Instagram"
                 class="w-8 h-8 rounded-lg flex items-center justify-center transition-colors hover:bg-white/10 hover:text-white"
                 style="border: 1px solid #30363d;">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
              </a>
              <!-- HuggingFace -->
              <a href="https://huggingface.co/AIRLab-POLIMI" target="_blank" rel="noopener"
                 aria-label="HuggingFace"
                 class="w-8 h-8 rounded-lg flex items-center justify-center transition-colors hover:bg-white/10 hover:text-white"
                 style="border: 1px solid #30363d;">
                <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.025 1.13c-5.77 0-10.449 4.647-10.449 10.378 0 1.112.178 2.181.503 3.185.064-.222.203-.444.416-.577a.96.96 0 0 1 .524-.15c.293 0 .584.124.84.284.278.173.48.408.71.694.226.282.458.611.684.951v-.014c.017-.324.106-.622.264-.874s.403-.487.762-.543c.3-.047.596.06.787.203s.31.313.4.467c.15.257.212.468.233.542.01.026.653 1.552 1.657 2.54.616.605 1.01 1.223 1.082 1.912.055.537-.096 1.059-.38 1.572.637.121 1.294.187 1.967.187.657 0 1.298-.063 1.921-.178-.287-.517-.44-1.041-.384-1.581.07-.69.465-1.307 1.081-1.913 1.004-.987 1.647-2.513 1.657-2.539.021-.074.083-.285.233-.542.09-.154.208-.323.4-.467a1.08 1.08 0 0 1 .787-.203c.359.056.604.29.762.543s.247.55.265.874v.015c.225-.34.457-.67.683-.952.23-.286.432-.52.71-.694.257-.16.547-.284.84-.285a.97.97 0 0 1 .524.151c.228.143.373.388.43.625l.006.04a10.3 10.3 0 0 0 .534-3.273c0-5.731-4.678-10.378-10.449-10.378M8.327 6.583a1.5 1.5 0 0 1 .713.174 1.487 1.487 0 0 1 .617 2.013c-.183.343-.762-.214-1.102-.094-.38.134-.532.914-.917.71a1.487 1.487 0 0 1 .69-2.803m7.486 0a1.487 1.487 0 0 1 .689 2.803c-.385.204-.536-.576-.916-.71-.34-.12-.92.437-1.103.094a1.487 1.487 0 0 1 .617-2.013 1.5 1.5 0 0 1 .713-.174m-10.68 1.55a.96.96 0 1 1 0 1.921.96.96 0 0 1 0-1.92m13.838 0a.96.96 0 1 1 0 1.92.96.96 0 0 1 0-1.92M8.489 11.458c.588.01 1.965 1.157 3.572 1.164 1.607-.007 2.984-1.155 3.572-1.164.196-.003.305.12.305.454 0 .886-.424 2.328-1.563 3.202-.22-.756-1.396-1.366-1.63-1.32q-.011.001-.02.006l-.044.026-.01.008-.03.024q-.018.017-.035.036l-.032.04a1 1 0 0 0-.058.09l-.014.025q-.049.088-.11.19a1 1 0 0 1-.083.116 1.2 1.2 0 0 1-.173.18q-.035.029-.075.058a1.3 1.3 0 0 1-.251-.243 1 1 0 0 1-.076-.107c-.124-.193-.177-.363-.337-.444-.034-.016-.104-.008-.2.022q-.094.03-.216.087-.06.028-.125.063l-.13.074q-.067.04-.136.086a3 3 0 0 0-.135.096 3 3 0 0 0-.26.219 2 2 0 0 0-.12.121 2 2 0 0 0-.106.128l-.002.002a2 2 0 0 0-.09.132l-.001.001a1.2 1.2 0 0 0-.105.212q-.013.036-.024.073c-1.139-.875-1.563-2.317-1.563-3.203 0-.334.109-.457.305-.454m.836 10.354c.824-1.19.766-2.082-.365-3.194-1.13-1.112-1.789-2.738-1.789-2.738s-.246-.945-.806-.858-.97 1.499.202 2.362c1.173.864-.233 1.45-.685.64-.45-.812-1.683-2.896-2.322-3.295s-1.089-.175-.938.647 2.822 2.813 2.562 3.244-1.176-.506-1.176-.506-2.866-2.567-3.49-1.898.473 1.23 2.037 2.16c1.564.932 1.686 1.178 1.464 1.53s-3.675-2.511-4-1.297c-.323 1.214 3.524 1.567 3.287 2.405-.238.839-2.71-1.587-3.216-.642-.506.946 3.49 2.056 3.522 2.064 1.29.33 4.568 1.028 5.713-.624m5.349 0c-.824-1.19-.766-2.082.365-3.194 1.13-1.112 1.789-2.738 1.789-2.738s.246-.945.806-.858.97 1.499-.202 2.362c-1.173.864.233 1.45.685.64.451-.812 1.683-2.896 2.322-3.295s1.089-.175.938.647-2.822 2.813-2.562 3.244 1.176-.506 1.176-.506 2.866-2.567 3.49-1.898-.473 1.23-2.037 2.16c-1.564.932-1.686 1.178-1.464 1.53s3.675-2.511 4-1.297c.323 1.214-3.524 1.567-3.287 2.405.238.839 2.71-1.587 3.216-.642.506.946-3.49 2.056-3.522 2.064-1.29.33-4.568 1.028-5.713-.624"/>
                </svg>
              </a>
            </div>
          </div>

        </div>

        <div class="border-t pt-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs" style="border-color: #21262d;">
          <p style="color: #8b949e;">© {new Date().getFullYear()} AIRLab — Politecnico di Milano. All rights reserved.</p>
          <p style="color: #8b949e;">
            Built with <a href="https://astro.build" class="hover:text-white transition-colors">Astro</a> &amp;
            <a href="https://tailwindcss.com" class="hover:text-white transition-colors">Tailwind CSS</a>
          </p>
        </div>
      </div>
    </footer>

    <!-- ── Vanta NET initialisation ──────────────────────────────────────── -->
    <script is:inline>
      (function () {
        // Guard: only run when both libs loaded (they're synchronous CDN scripts)
        if (typeof VANTA === 'undefined' || typeof THREE === 'undefined') return;

        var effect = VANTA.GLOBE({
          el: '#hero',
          THREE: THREE,
          mouseControls: true,
          touchControls: true,
          gyroControls: false,
          // ── Colors (mirrors theme.config.js) ──────────────────────────
          backgroundColor: 0x102c53,  // Polimi Heritage Blue
          color:           0x4d87d4,  // accent-400 — globe line colour
          color2:          0x1e5299,  // accent-700 — secondary dot colour
          // ── Scale ─────────────────────────────────────────────────────
          size:        1.2,
          scale:       1.0,
          scaleMobile: 0.75,
        });

        // Clean up if the user navigates away (prevents memory leaks on SPAs)
        window.addEventListener('beforeunload', function () {
          if (effect && effect.destroy) effect.destroy();
        });
      })();
    </script>
  </body>
</html>
